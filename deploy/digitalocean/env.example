# Copy: cp deploy/digitalocean/env.example /opt/1ex/.env
# Edit passwords before production.

APP_DIR=/opt/1ex
EX99_MONGO_URI=mongodb://127.0.0.1:27017
EX99_MONGO_DB=ex99_local

EX99_HOST=1ex.in
EX99_ADMIN_HOST=admin.1ex.in
EX99_CENTERPANEL_HOST=center.1ex.in
STAFF_HOST=staff.1ex.in

PORT_MAIN=1456
PORT_ADMIN=1457
PORT_CENTER=1458
PORT_STAFF=1460

EX99_LOCAL_ONLY=1
EX99_AUTO_DECISION=1
EX99_SCORECARD_LIVE_HUB=1
EX99_SCORECARD_PREWARM=1
EX99_MAX_HTTP_THREADS=200
EX99_LIVE_MATCHES=1
EX99_SCRAPE_LIVE_ONLY=1

# Live sport poll (scrape2 → output/sport, PM2: 1ex-sport-poll)
EX99_ENABLE_SPORT_POLL=1
EX99_ENABLE_CASINO_POLL=0
LOGIN_USER=Demo9304
LOGIN_PASS=
SPORT_POLL_INTERVAL=30
SPORT_MATCH_DETAIL=1
USE_FLARESOLVERR=1
FLARESOLVERR_URL=http://127.0.0.1:8191/v1

# WNP9 staff auto-declare (optional)
WNP9_USERNAME=OW1000
WNP9_PASSWORD=
WNP9_API_BASE=https://api.wnp9.pro/v1/

# SSL domains (certbot)
API_MAIN_DOMAIN=api.1ex.in
API_ADMIN_DOMAIN=api-admin.1ex.in
API_CENTER_DOMAIN=api-center.1ex.in
API_STAFF_DOMAIN=api-staff.1ex.in
