{
  "buildCommand": "python3 ../../scripts/vercel_build.py admin || python ../../scripts/vercel_build.py admin",
  "outputDirectory": "dist",
  "installCommand": "python3 -m pip install -r ../../backend/requirements.txt -q || python -m pip install -r ../../backend/requirements.txt -q",
  "framework": null,
  "rewrites": [
    { "source": "/v1/:path*", "destination": "https://api-admin.1ex.in/v1/:path*" },
    { "source": "/excache/:path*", "destination": "https://api-admin.1ex.in/excache/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/static/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    }
  ]
}
